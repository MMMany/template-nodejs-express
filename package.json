{
  "name": "template-nodejs-express",
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "start": "cross-env NODE_ENV=development nodemon -r module-alias/register src/main.js",
    "serve": "cross-env NODE_ENV=production node -r module-alias/register src/main.js",
    "test": "cross-env NODE_ENV=test jest --noStackTrace --bail ./tests/",
    "test:ci": "cross-env NODE_ENV=test CI=true jest --noStackTrace --bail --runInBand ./tests/",
    "test:coverage": "cross-env NODE_ENV=test jest --noStackTrace --bail --coverage ./tests/",
    "lint": "eslint .",
    "format": "prettier --write . && prettier --check .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "module-alias": "^2.3.4",
    "mongoose": "^9.7.1",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^9.9.0",
    "@jest/globals": "^29.7.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2"
  },
  "_moduleAliases": {
    "#": "./src",
    "#modules": "./src/modules",
    "#shared": "./src/shared"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,ts,css,md}": "prettier --write"
  }
}
