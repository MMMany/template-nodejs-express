{
  "name": "template-nodejs-express",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=development nodemon src/main.js",
    "serve": "cross-env NODE_ENV=production node src/main.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --noStackTrace --bail --detectOpenHandles",
    "test:ci": "cross-env CI=true npm test -- --runInBand",
    "lint": "eslint .",
    "format": "prettier --write . && prettier --check .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "typecheck": "tsc --noEmit"
  },
  "license": "ISC",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "express": "^5.2.1",
    "lodash-es": "^4.18.1",
    "mongoose": "^9.3.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.7.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/lodash-es": "^4.17.12",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  },
  "imports": {
    "#app": "./src/main.js",
    "#db/setup": "./src/db/setup.js",
    "#db/mongoose": "./src/db/mongoose.js",
    "#modules/*": "./src/modules/*/index.js",
    "#shared/constants": "./src/shared/constants.js",
    "#shared/*": "./src/shared/*/index.js"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,ts,css,md}": "prettier --write"
  }
}
