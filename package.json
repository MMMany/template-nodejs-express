{
  "name": "template-nodejs-express",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=development nodemon src/main.js",
    "serve": "cross-env NODE_ENV=production node src/main.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --noStackTrace --bail --detectOpenHandles",
    "test:ci": "cross-env CI=true npm test -- --runInBand",
    "lint": "eslint .",
    "format": "prettier --write . && prettier --check .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "license": "ISC",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "joi": "^18.0.2",
    "lodash-es": "^4.17.23",
    "module-alias": "^2.3.4",
    "mongoose": "^9.3.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  },
  "imports": {
    "#src/*": "./src/*",
    "#types/*": "./types/*"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*.{js,ts,css,md}": "prettier --write"
  }
}
