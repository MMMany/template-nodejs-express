{
  "name": "template-nodejs-express",
  "version": "0.1.0",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=development nodemon src/app.js",
    "serve": "cross-env NODE_ENV=production node src/app.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --noStackTrace",
    "lint": "eslint .",
    "format": "prettier --write . && prettier --check .",
    "format:check": "prettier --check ."
  },
  "license": "ISC",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.0",
    "dotenv-expand": "^12.0.2",
    "express": "^5.1.0",
    "fs-extra": "^11.3.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "lodash": "^4.17.21",
    "mongodb": "^6.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@jest/globals": "^30.0.4",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "globals": "^16.3.0",
    "jest": "^30.0.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.3"
  }
}
