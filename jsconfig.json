{
  "compilerOptions": {
    "checkJs": true,
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node", "jest"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "paths": {
      "#/*": ["./src/*"]
    }
  },
  "include": ["src", "tests", "types"]
}
